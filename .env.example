# Environment Variables for Chain-Link Server

# Private key for transaction signing (without 0x prefix or with, ethers handles both)
PRIVATE_KEY=

# Polygon Amoy Testnet
POLYGON_AMOY_RPC=https://rpc-amoy.polygon.technology
POLYGON_AMOY_REGISTRY_ADDRESS=0xc1a356C55941F308f3ce29E266a89F19e3b297D2

# Ethereum Sepolia Testnet
SEPOLIA_RPC=https://rpc.sepolia.org
SEPOLIA_REGISTRY_ADDRESS=0xa700f388dbC3083D7e82fD7AaBD711a11eFb86e7

# Server port (optional, defaults to 3000)
PORT=3000

# Hyperledger Fabric Configuration
FABRIC_MSP_ID=Org1MSP
FABRIC_CHANNEL_NAME=mychannel
FABRIC_CHAINCODE_NAME=Registry
FABRIC_PEER_ENDPOINT=localhost:7051
FABRIC_PEER_HOST_ALIAS=peer0.org1.example.com

# Raw contents of Fabric Cryptographic Materials
# Replace real newlines in certificates and keys with \n literal text.
FABRIC_TLS_CERT="-----BEGIN CERTIFICATE-----\n..."
FABRIC_CERT="-----BEGIN CERTIFICATE-----\n..."
FABRIC_KEY="-----BEGIN PRIVATE KEY-----\n..."

# MongoDB
MONGODB_URI=mongodb+srv://dev:49mskFt0zBArTUCi@novioze-hrm.plmqyfg.mongodb.net/
JWT_SECRET=super_secret_jwt_key_here
JWT_EXPIRES_IN=1h
